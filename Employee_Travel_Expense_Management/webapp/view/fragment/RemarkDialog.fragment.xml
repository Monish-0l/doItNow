<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog title="Manager Remarks">

    <VBox class="sapUiSmallMargin">
     <TextArea
    id="remarkInput"
    placeholder="Enter remarks"
    rows="4"/>
    </VBox>

    <beginButton>
      <Button text="Submit" press="onConfirmAction"/>
    </beginButton>

    <endButton>
      <Button text="Cancel" press="onCloseDialog"/>
    </endButton>

  </Dialog>
</core:FragmentDefinition>